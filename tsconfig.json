{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["webpack-env"],
    "lib": ["DOM", "DOM.Iterable", "ES2020", "WebWorker"]
  },
  "include": [
    "container/src",
    "mfe-policies/src",
    "mfe-payments/src"
  ]
}
