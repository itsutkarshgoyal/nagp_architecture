{
  "name": "client-side-architecture-assignment",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "start:container": "npx webpack serve --config container/webpack.config.js --mode development",
    "start:policies": "npx webpack serve --config mfe-policies/webpack.config.js --mode development",
    "start:payments": "npx webpack serve --config mfe-payments/webpack.config.js --mode development",
    "build:container": "npx webpack --config container/webpack.config.js --mode production",
    "build:policies": "npx webpack --config mfe-policies/webpack.config.js --mode production",
    "build:payments": "npx webpack --config mfe-payments/webpack.config.js --mode production",
    "build:all": "npm run build:container && npm run build:policies && npm run build:payments"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/react-router-dom": "^5.3.3",
    "@types/webpack-env": "^1.18.5",
    "typescript": "^5.6.3",
    "ts-loader": "^9.5.1",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "html-webpack-plugin": "^5.6.0",
    "sass": "^1.77.0",
    "sass-loader": "^14.2.1",
    "css-loader": "^7.1.1",
    "style-loader": "^4.0.0"
  }
}
